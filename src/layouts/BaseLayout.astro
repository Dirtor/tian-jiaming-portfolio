---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <!-- restore saved lang preference before paint to avoid flash -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem("lang");
        if (saved === "zh") {
          document.documentElement.setAttribute("data-lang", "zh");
        }
      })();
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      // ── Lang toggle ──────────────────────────────
      const btn = document.getElementById("lang-toggle");
      if (btn) {
        const html = document.documentElement;
        btn.addEventListener("click", () => {
          const next = html.getAttribute("data-lang") === "zh" ? "en" : "zh";
          html.setAttribute("data-lang", next);
          localStorage.setItem("lang", next);
        });
      }

      // ── Full-page section navigation ─────────────
      const sections = [
        ...document.querySelectorAll<HTMLElement>(".hero-section, .section"),
      ];
      let current = 0;
      let lastNav = 0;
      const COOLDOWN = 1200; // ms — must be > scroll animation duration

      function goTo(index: number) {
        if (index < 0 || index >= sections.length) return;
        current = index;
        lastNav = Date.now();
        window.scrollTo({
          top: sections[index].offsetTop,
          behavior: "smooth",
        });
      }

      // Wheel: one gesture = one section
      window.addEventListener("wheel", (e) => {
        e.preventDefault();
        if (Date.now() - lastNav < COOLDOWN) return;
        // normalise delta: line mode (1) ≈ 40px, pixel mode (0) as-is
        const delta = e.deltaMode === 1 ? e.deltaY * 40 : e.deltaY;
        if (Math.abs(delta) < 20) return; // filter tiny inertia
        goTo(delta > 0 ? current + 1 : current - 1);
      }, { passive: false });

      // Keyboard
      window.addEventListener("keydown", (e) => {
        if (e.key === "ArrowDown" || e.key === "PageDown") goTo(current + 1);
        if (e.key === "ArrowUp"   || e.key === "PageUp"  ) goTo(current - 1);
      });

      // Nav links
      document.querySelectorAll(".nav-links a").forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const href = (link as HTMLAnchorElement).getAttribute("href") ?? "";
          const target = document.querySelector<HTMLElement>(href);
          if (!target) return;
          const idx = sections.indexOf(target);
          if (idx !== -1) goTo(idx);
        });
      });

      // ── Section entrance animations ───────────────
      sections.forEach((section) => {
        const children = Array.from(section.children) as HTMLElement[];
        gsap.from(children, {
          opacity: 0,
          y: 48,
          duration: 1.4,
          ease: "power3.out",
          stagger: 0.18,
          scrollTrigger: {
            trigger: section,
            start: "top 80%",
            once: true,
          },
        });
      });
    </script>
  </body>
</html>
