---
import SparkMark from "./SparkMark.astro";
import { hero } from "@/data/portfolio";
---

<header class="hero-section">
  <nav class="hero-nav" aria-label="Primary navigation">
    <a class="brand" href="#top" aria-label="Tian Jiaming home">
      <SparkMark />
      <span>{hero.name}</span>
    </a>
    <div class="nav-links">
      <a href="#work"  ><span class="lang-en">Work</span>   <span class="lang-zh">项目</span></a>
      <a href="#notes" ><span class="lang-en">Notes</span>  <span class="lang-zh">思考</span></a>
      <a href="#profile"><span class="lang-en">Profile</span><span class="lang-zh">关于</span></a>
      <a href="#contact"><span class="lang-en">Contact</span><span class="lang-zh">联系</span></a>
      <button id="lang-toggle" class="lang-toggle" aria-label="Switch language">
        <span class="lang-en">中文</span>
        <span class="lang-zh">EN</span>
      </button>
    </div>
  </nav>

  <div class="hero-grid" id="top">
    <div class="hero-copy">
      <p class="hero-kicker">AI product systems / 个人作品集</p>

      <h1 class="lang-en">
        <span>I turn</span><br>
        <span class="headline-muted">AI ideas</span><br>
        <span>into real</span><br>
        <span class="headline-accent">product systems.</span>
      </h1>
      <h1 class="lang-zh">
        <span>把</span><br>
        <span class="headline-muted">AI 想法</span><br>
        <span>变成真实</span><br>
        <span class="headline-accent">产品系统。</span>
      </h1>

      <p class="hero-subtitle lang-en">Turning AI product ideas<br>into real, usable systems.</p>
      <p class="hero-subtitle lang-zh">{hero.subtitle}</p>
      <p class="hero-description lang-en">{hero.description}</p>
      <p class="hero-description lang-zh">{hero.descriptionZh}</p>

      <div class="hero-tags" aria-label="Focus areas">
        <span class="lang-en">{hero.tags.map((tag) => <span>{tag}</span>)}</span>
        <span class="lang-zh">{hero.tagsZh.map((tag) => <span>{tag}</span>)}</span>
      </div>

      <div class="button-row">
        <a class="button primary" href="#work">
          <span class="lang-en">View work</span>
          <span class="lang-zh">查看项目</span>
        </a>
        <a class="button dark" href={`mailto:${hero.email}`}>
          <span class="lang-en">Contact</span>
          <span class="lang-zh">联系我</span>
        </a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <img src="/tian-jiaming-portfolio/hero-composite.png" alt="" class="hero-avatar" />
    </div>
  </div>
</header>
