---
import SparkMark from "./SparkMark.astro";
import { profile, experience } from "@/data/portfolio";
---

<section class="section profile-section" id="profile">
  <p class="section-label"><SparkMark /> Profile</p>

  <div class="profile-layout">
    <div class="profile-intro">
      <h2><span>Finance-trained,</span> <span class="headline-muted">product-led,</span> <span class="headline-accent">AI-focused.</span></h2>
      <p class="profile-education">{profile.education}</p>
      <p class="profile-education-detail">{profile.educationDetail}</p>
      <p class="profile-certs">{profile.certifications}</p>
    </div>
    <div class="profile-avatar-wrap">
      <img
        src="/tian-jiaming-portfolio/avatar.PNG"
        alt="Tian Jiaming"
        class="profile-avatar"
        width="420"
        height="420"
      />
    </div>
  </div>

  <div class="experience-list" aria-label="Work experience">
    {experience.map((item) => (
      <div class="experience-item">
        <div class="experience-header">
          <div class="experience-left">
            <span class="experience-company">{item.company}</span>
            <span class="experience-role">{item.role}</span>
          </div>
          <span class="experience-period">{item.period}</span>
        </div>
        <p class="experience-achievement">{item.achievement}</p>
      </div>
    ))}
  </div>

  <div class="skill-strip" aria-label="Skills and languages">
    {profile.skills.map((skill) => <span>{skill}</span>)}
  </div>
</section>
