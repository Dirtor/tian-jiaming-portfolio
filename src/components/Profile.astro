---
import SparkMark from "./SparkMark.astro";
import { profile, experience } from "@/data/portfolio";
---

<section class="section profile-section" id="profile">
  <p class="section-label"><SparkMark />
    <span class="lang-en">Profile</span>
    <span class="lang-zh">关于我</span>
  </p>

  <div class="profile-layout">
    <div class="profile-intro">
      <h2>
        <span class="lang-en"><span>Finance-trained,</span> <span class="headline-muted">product-led,</span> <span class="headline-accent">AI-focused.</span></span>
        <span class="lang-zh"><span>金融出身，</span><span class="headline-muted">产品驱动，</span><span class="headline-accent">专注 AI。</span></span>
      </h2>
      <p class="profile-education lang-en">{profile.education}</p>
      <p class="profile-education lang-zh">{profile.educationZh}</p>
      <p class="profile-education-detail lang-en">{profile.educationDetail}</p>
      <p class="profile-education-detail lang-zh">{profile.educationDetailZh}</p>
      <p class="profile-certs lang-en">{profile.certifications}</p>
      <p class="profile-certs lang-zh">{profile.certificationsZh}</p>
    </div>
    <div class="profile-signals" aria-label="Profile signals">
      {profile.signals.map((signal) => (
        <div class="profile-signal">
          <span class="profile-signal-label lang-en">{signal.label}</span>
          <span class="profile-signal-label lang-zh">{signal.labelZh}</span>
          <span class="profile-signal-value lang-en">{signal.value}</span>
          <span class="profile-signal-value lang-zh">{signal.valueZh}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="experience-list" aria-label="Work experience">
    {experience.map((item) => (
      <div class="experience-item">
        <div class="experience-header">
          <div class="experience-left">
            <span class="experience-company lang-en">{item.companyEn ?? item.company}</span>
            <span class="experience-company lang-zh">{item.companyZh ?? item.company}</span>
            <span class="experience-role lang-en">{item.role}</span>
            <span class="experience-role lang-zh">{item.roleZh}</span>
          </div>
          <span class="experience-period">{item.period}</span>
        </div>
      </div>
    ))}
  </div>

  <div class="skill-strip" aria-label="Skills and languages">
    {profile.skills.map((skill) => <span>{skill}</span>)}
  </div>
</section>
