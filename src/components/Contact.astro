---
import SparkMark from "./SparkMark.astro";
import { contact, hero, projects } from "@/data/portfolio";
---

<section class="section contact-section" id="contact">
  <div class="contact-panel">
    <p class="section-label"><SparkMark />
      <span class="lang-en">Contact</span>
      <span class="lang-zh">联系我</span>
    </p>
    <h2>
      <span class="lang-en">{contact.heading}</span>
      <span class="lang-zh">{contact.headingZh}</span>
    </h2>
    <p>
      <span class="lang-en">{contact.body}</span>
      <span class="lang-zh">{contact.bodyZh}</span>
    </p>
    <div class="button-row">
      <a class="button primary" href={`mailto:${hero.email}`}>
        <span class="lang-en">Email me</span>
        <span class="lang-zh">发邮件</span>
      </a>
      {projects.map((project) => (
        <a
          class="button"
          href={project.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${project.title} on GitHub`}
        >
          {project.title}
        </a>
      ))}
    </div>
  </div>
</section>
