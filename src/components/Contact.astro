---
import SparkMark from "./SparkMark.astro";
import { hero, projects } from "@/data/portfolio";
---

<section class="section contact-section" id="contact">
  <div class="contact-panel reveal" data-delay="0">
    <p class="section-label"><SparkMark />
      <span class="lang-en">Contact</span>
      <span class="lang-zh">联系我</span>
    </p>
    <h2>
      <span class="lang-en"><span>Interested in</span> <span class="headline-accent">AI product systems,</span> <span class="headline-muted">classroom technology, or useful automation?</span></span>
      <span class="lang-zh"><span>对</span><span class="headline-accent"> AI 产品系统、</span><span class="headline-muted">课堂技术或实用自动化感兴趣？</span></span>
    </h2>
    <p>
      <span class="lang-en">Reach out for product conversations, collaboration, or role-fit discussions.</span>
      <span class="lang-zh">欢迎就产品方向、合作机会或职位匹配展开对话。</span>
    </p>
    <div class="button-row">
      <a class="button primary" href={`mailto:${hero.email}`}>
        <span class="lang-en">Email me</span>
        <span class="lang-zh">发邮件</span>
      </a>
      {projects.map((project) => (
        <a
          class="button"
          href={project.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${project.title} on GitHub`}
        >
          {project.title}
        </a>
      ))}
    </div>
  </div>
</section>
