---
import ProjectCard from "./ProjectCard.astro";
import SparkMark from "./SparkMark.astro";
import { projects } from "@/data/portfolio";
---

<section class="section work-section" id="work">
  <p class="section-label"><SparkMark />
    <span class="lang-en">Selected Work</span>
    <span class="lang-zh">代表项目</span>
  </p>
  <div class="section-heading">
    <h2>
      <span class="lang-en"><span>Cue.AI examples,</span> <span class="headline-muted">from classroom to team operations.</span></span>
      <span class="lang-zh"><span>Cue.AI 例子，</span><span class="headline-muted">从课堂到团队操作系统。</span></span>
    </h2>
    <p>
      <span class="lang-en">Cue.Room and Cue.Hub are the current product examples under Cue.AI. OmniNexus and Cue.AI are separate parallel projects.</span>
      <span class="lang-zh">Cue.Room 与 Cue.Hub 是 Cue.AI 方向下当前的产品例子。OmniNexus 与 Cue.AI 是两个并行项目。</span>
    </p>
  </div>
  <div class="project-grid">
    {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
  </div>
</section>
